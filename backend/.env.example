# Server Configuration
PORT=3000
NODE_ENV=production

# MongoDB Configuration (MongoDB Atlas)
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/intervalflow?appName=Cluster0

# JWT Configuration
JWT_SECRET=change-this-to-random-secure-string-in-production
JWT_EXPIRE=7d

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app